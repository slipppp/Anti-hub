-- ATUALIZA STATUS QUANDO SELECIONA JOGADOR
local function updateStatus()
    if selectedPlayer then
        local humanoid = selectedPlayer.Character and selectedPlayer.Character:FindFirstChild("Humanoid")
        local health = humanoid and math.floor(humanoid.Health) or 0
        StatusText.Text = "Selecionado: " .. selectedPlayer.Name .. " ❤️ " .. health
        StatusText.TextColor3 = Color3.fromRGB(100, 255, 100)
        SubTitle.Text = "Jogador no FOV!"
    else
        StatusText.Text = "Nenhum jogador selecionado"
        StatusText.TextColor3 = Color3.fromRGB(255, 100, 100)
        SubTitle.Text = "Mire em um jogador para selecionar"
    end
end

-- ATUALIZA STATUS PERIODICAMENTE
