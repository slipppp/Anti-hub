-- FUNÇÃO PARA TELEPORTAR BALA ATÉ O JOGADOR SELECIONADO
local function teleportBulletToPlayer()
    if not selectedPlayer or not selectedPlayer.Character then 
        return false 
    end
    
    local character = selectedPlayer.Character
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then 
        return false 
    end
    
    -- Pega a parte do corpo para acertar (Head ou Torso)
    local targetPart = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    if not targetPart then return false end
    
    -- Posição do alvo
    local targetPosition = targetPart.Position
    
    -- Pega a arma que o jogador está usando
    local currentChar = Player.Character
    if not currentChar then return false end
    
    -- Procura por ferramentas/armas
    local tool = currentChar:FindFirstChildOfClass("Tool")
    if not tool then 
        -- Se não tiver ferramenta, tenta encontrar qualquer parte que possa atirar
        return false 
    end
    
    -- Procura por um ponto de tiro (fire point)
    local firePoint = nil
    for _, child in pairs(tool:GetDescendants()) do
        if child:IsA("Part") and (child.Name:lower():find("fire") or child.Name:lower():find("barrel") or child.Name:lower():find("tip")) then
            firePoint = child
            break
        end
    end
    
    -- Se não achou fire point, usa a posição da ferramenta
    if not firePoint then
        firePoint = tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("Part")
    end
    
    if not firePoint then return false end
    
    -- Cria a bala (ou modifica a existente)
    local bullet = Instance.new("Part")
    bullet.Name = "BulletTP"
    bullet.Size = Vector3.new(0.2, 0.2, 1)
    bullet.Shape = Enum.PartType.Ball
    bullet.Material = Enum.Material.Neon
    bullet.Color = Color3.fromRGB(255, 0, 0)
    bullet.CanCollide = false
    bullet.Anchored = false
    bullet.Parent = workspace
    
    -- Coloca a bala no ponto de tiro
    local fireWorldPos = firePoint.Parent and firePoint.Parent:GetPivot() and firePoint.Parent:GetPivot().Position + Vector3.new(0, 1.5, 0) or 
                         currentChar:FindFirstChild("HumanoidRootPart") and currentChar.HumanoidRootPart.Position + Vector3.new(0, 1.5, 0) or 
                         Vector3.new(0, 10, 0)
    
    bullet.Position = fireWorldPos
    
    -- Faz a bala voar rapidamente até o alvo (teleporte)
    local distance = (targetPosition - bullet.Position).Magnitude
    local speed = 1000 -- Velocidade muito alta pra parecer teleporte
    
    -- Tween da bala até o alvo
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not bullet or not bullet.Parent then 
            if connection then connection:Disconnect() end
            return 
        end
        
        if not selectedPlayer or not selectedPlayer.Character then
            bullet:Destroy()
            if connection then connection:Disconnect() end
            return
        end
        
        local currentTarget = selectedPlayer.Character:FindFirstChild("Head") or selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not currentTarget then
            bullet:Destroy()
            if connection then connection:Disconnect() end
            return
        end
        
        local targetPos = currentTarget.Position
        
        -- Move a bala em direção ao alvo
        local direction = (targetPos - bullet.Position).unit
        local step = speed * 0.016 -- Aproximadamente 60 FPS
        
        if (targetPos - bullet.Position).Magnitude < step then
            -- CHEGOU NO ALVO!
            bullet.Position = targetPos
            
            -- DANO NO JOGADOR
            local humanoid = selectedPlayer.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                -- Dá dano (mata instantaneamente)
                humanoid.Health = 0
                
                -- Efeito de explosão/sangue
                local explosion = Instance.new("Part")
                explosion.Name = "ExplosionEffect"
                explosion.Size = Vector3.new(3, 3, 3)
                explosion.Shape = Enum.PartType.Ball
                explosion.Material = Enum.Material.Neon
                explosion.Color = Color3.fromRGB(255, 0, 0)
                explosion.CanCollide = false
                explosion.Anchored = true
                explosion.Position = targetPos
                explosion.Parent = workspace
                
                -- Efeito de luz
                local light = Instance.new("PointLight")
                light.Parent = explosion
                light.Color = Color3.fromRGB(255, 0, 0)
                light.Brightness = 5
                light.Range = 20
                
                -- Anima a explosão
                task.spawn(function()
                    for i = 1, 20 do
                        explosion.Size = explosion.Size + Vector3.new(0.3, 0.3, 0.3)
                        explosion.Transparency = i / 20
                        task.wait(0.05)
                    end
                    explosion:Destroy()
                end)
                
                -- Notificação
                notify("💀 " .. selectedPlayer.Name .. " foi morto!", Color3.fromRGB(255, 0, 0))
            end
            
            bullet:Destroy()
            if connection then connection:Disconnect() end
            return
        end
        
        -- Move a bala
        bullet.Position = bullet.Position + direction * step
        
        -- Rotaciona a bala pra apontar pro alvo
        bullet.CFrame = CFrame.lookAt(bullet.Position, targetPos)
        
        -- Efeito de rastro
        local trail = Instance.new("Part")
        trail.Name = "BulletTrail"
        trail.Size = Vector3.new(0.1, 0.1, 0.5)
        trail.Material = Enum.Material.Neon
        trail.Color = Color3.fromRGB(255, 200, 50)
        trail.CanCollide = false
        trail.Anchored = true
        trail.Position = bullet.Position
        trail.Parent = workspace
        trail.Transparency = 0.7
        
        task.spawn(function()
            task.wait(0.1)
            trail:Destroy()
        end)
    end)
    
    return true
end

-- FUNÇÃO PARA DETECTAR DISPARO
local function onShoot()
    if not bulletTeleportEnabled then return end
    if not selectedPlayer then 
        notify("⚠️ Nenhum jogador selecionado!", Color3.fromRGB(255, 200, 0))
        return 
    end
    
    teleportBulletToPlayer()
end

-- DETECTA QUANDO O JOGADOR CLICA (ATIRA)
Mouse.Button1Down:Connect(function()
    -- Verifica se está segurando uma ferramenta/arma
    local char = Player.Character
    if char and char:FindFirstChildOfClass("Tool") then
        onShoot()
    end
end)

-- DETECTA QUANDO USA UMA FERRAMENTA (para armas que usam .Tool)
local function onToolActivated(tool)
    if tool and bulletTeleportEnabled then
        -- Espera um pouco pra garantir que a bala foi criada
        task.wait(0.05)
        onShoot()
    end
end

-- Detecta quando uma ferramenta é ativada
local function hookTool(tool)
    if tool and tool:IsA("Tool") then
        -- Hook no Activated
        local oldActivated = tool.Activated
        tool.Activated = function(...)
            if oldActivated then oldActivated(...) end
            onShoot()
        end
    end
end

-- Hook nas ferramentas existentes
for _, tool in pairs(Player.Backpack:GetChildren()) do
    if tool:IsA("Tool") then
        hookTool(tool)
    end
end

-- Hook quando uma nova ferramenta é adicionada
Player.Backpack.ChildAdded:Connect(function(child)
    if child:IsA("Tool") then
        hookTool(child)
    end
end)

-- Hook quando o jogador equipa uma ferramenta
Player.CharacterAdded:Connect(function(character)
    task.wait(0.5)
    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        hookTool(tool)
    end
end)

-- ========== HIGHLIGHT ==========
local function createHighlight(character)
    if not character then return nil end
    for _, child in pairs(character:GetChildren()) do
        if child:IsA("Highlight") then
            child:Destroy()
        end
    end
    local highlight = Instance.new("Highlight")
    highlight.Parent = character
    highlight.FillColor = highlightColor
    highlight.FillTransparency = 0.4
    highlight.OutlineColor = highlightColor
    highlight.OutlineTransparency = 0.2
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = false
    return highlight
end

local function selectPlayer(player)
    if selectedHighlight then
        selectedHighlight.Enabled = false
        selectedHighlight = nil
    end
    selectedPlayer = player
    if player and player.Character then
        selectedHighlight = createHighlight(player.Character)
        if selectedHighlight then
            selectedHighlight.Enabled = true
            task.spawn(function()
                while selectedHighlight and selectedHighlight.Enabled do
                    for i = 0.4, 0.7, 0.05 do
                        if not selectedHighlight or not selectedHighlight.Enabled then break end
                        selectedHighlight.FillTransparency = i
                        selectedHighlight.OutlineTransparency = i - 0.2
                        task.wait(0.05)
                    end
                    for i = 0.7, 0.4, -0.05 do
                        if not selectedHighlight or not selectedHighlight.Enabled then break end
                        selectedHighlight.FillTransparency = i
                        selectedHighlight.OutlineTransparency = i - 0.2
                        task.wait(0.05)
                    end
                end
            end)
        end
    end
    updateStatus()
end

-- ========== FOV ==========
local function isPlayerInFOV(player)
    if not player or not player.Character then return false end
    if player == Player then return false end
    local character = player.Character
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    local targetPart = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    if not targetPart then return false end
    local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
    if not onScreen then return false end
    local center = Camera.ViewportSize / 2
    local distance = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
    return distance <= fovRadius
end

local function findClosestPlayerInFOV()
    local closest = nil
    local closestDist = math.huge
    local center = Camera.ViewportSize / 2
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Player and player.Character then
            local targetPart = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
            if targetPart then
                local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist <= fovRadius and dist < closestDist then
                        closestDist = dist
                        closest = player
                    end
                end
            end
        end
    end
    return closest
end

-- LOOP DE SELEÇÃO
RunService.RenderStepped:Connect(function()
    if not selectionEnabled then return end
    local target = findClosestPlayerInFOV()
    if target and target ~= selectedPlayer then
        selectPlayer(target)
    elseif not target and selectedPlayer then
        if selectedHighlight then
            selectedHighlight.Enabled = false
            selectedHighlight = nil
        end
        selectedPlayer = nil
        updateStatus()
    end
end)

