-- ========== SILENT AIM ==========
-- Hook nos tiros para redirecionar
local function getTargetPart()
    if not selectedPlayer or not selectedPlayer.Character then return nil end
    
    local character = selectedPlayer.Character
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return nil end
    
    -- Escolhe a parte do corpo
    local parts = {
        Head = character:FindFirstChild("Head"),
        Torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"),
        HumanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    }
    
    return parts[aimPart] or parts.Head
end

-- Função para redirecionar o tiro
local function redirectShot(tool)
    if not silentAimEnabled then return end
    if not selectedPlayer then return end
    
    local targetPart = getTargetPart()
    if not targetPart then return end
    
    -- Pega o Handle da ferramenta
    local handle = tool:FindFirstChild("Handle")
    if not handle then return end
    
    -- Cria um raycast da arma até o alvo
    local origin = handle.Position
    local direction = (targetPart.Position - origin).unit
    local distance = (targetPart.Position - origin).Magnitude
    
    -- Força o tiro a ir na direção do alvo
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {Player.Character}
    
    local result = workspace:Raycast(origin, direction * distance, params)
    
    -- Se acertou o alvo, aplica dano
    if result and result.Instance then
        local hitChar = result.Instance.Parent
        if hitChar then
            local humanoid = hitChar:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                -- Dano (mata)
                humanoid.Health = 0
                
                -- Efeito visual
                createHitEffect(targetPart.Position)
                
                -- Notificação
                notify("💀 " .. selectedPlayer.Name .. " morto!", Color3.fromRGB(255, 0, 0))
            end
        end
    end
end

-- Efeito de impacto
local function createHitEffect(position)
    -- Explosão
    local explosion = Instance.new("Part")
    explosion.Name = "HitEffect"
    explosion.Size = Vector3.new(2, 2, 2)
    explosion.Shape = Enum.PartType.Ball
    explosion.Material = Enum.Material.Neon
    explosion.Color = Color3.fromRGB(255, 0, 0)
    explosion.CanCollide = false
    explosion.Anchored = true
    explosion.Position = position
    explosion.Parent = workspace
    
    local light = Instance.new("PointLight")
    light.Parent = explosion
    light.Color = Color3.fromRGB(255, 0, 0)
    light.Brightness = 10
    light.Range = 30
    
    task.spawn(function()
        for i = 1, 15 do
            explosion.Size = explosion.Size + Vector3.new(0.4, 0.4, 0.4)
            explosion.Transparency = i / 15
            task.wait(0.03)
        end
        explosion:Destroy()
    end)
    
    -- Partículas de sangue (opcional)
    for i = 1, 20 do
        local blood = Instance.new("Part")
        blood.Size = Vector3.new(0.2, 0.2, 0.2)
        blood.Shape = Enum.PartType.Ball
        blood.Material = Enum.Material.Neon
        blood.Color = Color3.fromRGB(200, 0, 0)
        blood.CanCollide = false
        blood.Anchored = false
        blood.Position = position + Vector3.new(
            math.random(-2, 2),
            math.random(-2, 2),
            math.random(-2, 2)
        )
        blood.Parent = workspace
        
        local velocity = Vector3.new(
            math.random(-10, 10),
            math.random(5, 15),
            math.random(-10, 10)
        )
        blood.AssemblyLinearVelocity = velocity
        
        task.spawn(function()
            task.wait(0.5)
            blood:Destroy()
        end)
    end
end

-- ========== HOOK NAS ARMAS ==========
local function hookTool(tool)
    if not tool:IsA("Tool") then return end
    
    -- Hook no evento de tiro
    local oldActivated = tool.Activated
    tool.Activated = function(...)
        if oldActivated then 
            pcall(function() oldActivated(...) end)
        end
        
        -- Executa o silent aim
        task.spawn(function()
            redirectShot(tool)
        end)
    end
end

-- Hook em todas as ferramentas
local function hookAllTools()
    for _, tool in pairs(Player.Backpack:GetChildren()) do
        hookTool(tool)
    end
    for _, tool in pairs(Player.Character:GetChildren()) do
        if tool:IsA("Tool") then
            hookTool(tool)
        end
    end
end

-- Hook quando ferramenta é adicionada
Player.Backpack.ChildAdded:Connect(function(child)
    task.wait(0.1)
    hookTool(child)
end)

-- Hook quando o jogador equipa uma ferramenta
Player.CharacterAdded:Connect(function(character)
    task.wait(0.5)
    hookAllTools()
end)

-- Hook inicial
